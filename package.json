{
  "name": "ai-suites-web",
  "version": "0.1.0",
  "description": "AI Suites — Web version for personalization and paid media campaign management",
  "author": "Treasure Data DevAI Unit",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n server,client -c blue,green \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:client": "vite --config vite.web.config.ts",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --config vite.web.config.ts",
    "build:vercel": "vite build --config vite.web.config.ts",
    "build:server": "tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.server.json --noEmit",
    "prepare-deploy": "bash prepare-deploy.sh"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/manrope": "^5.2.8",
    "@grapesjs/react": "^2.0.0",
    "cheerio": "^1.2.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "googleapis": "^171.4.0",
    "grapesjs": "^0.22.14",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.563.0",
    "mammoth": "^1.11.0",
    "nodemailer": "^8.0.3",
    "pdf-parse": "^1.1.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.4",
    "react-router-dom": "^7.13.0",
    "react-syntax-highlighter": "^16.1.0",
    "recharts": "^3.4.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^25.2.2",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^5.1.3",
    "concurrently": "^9.1.0",
    "globals": "^17.3.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.19.0",
    "typescript": "^5.7.2",
    "vite": "^7.3.1"
  }
}
