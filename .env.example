# API key for the LLM proxy (Treasure Data)
API_KEY=your-api-key-here

# LLM proxy URL
LLM_PROXY_URL=https://llm-proxy.us01.treasuredata.com

# Optional: Claude model to use
MODEL=claude-sonnet-4-20250514

# Optional: App password for access control
APP_PASSWORD=

# Optional: Meta Ads
META_APP_ID=
META_APP_SECRET=

# Server port
PORT=3001
