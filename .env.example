# API key for the LLM proxy (Treasure Data) — used by the server proxy
API_KEY=your-api-key-here

# LLM proxy URL
LLM_PROXY_URL=https://llm-proxy.us01.treasuredata.com

# Optional: Claude model to use
MODEL=claude-sonnet-4-20250514

# Optional: App password for access control
APP_PASSWORD=

# Server port
PORT=3001

# Sandbox API key — embedded at build time so users don't need to enter their own key
VITE_SANDBOX_API_KEY=

# Direct LLM calls — set to "true" when TD LLM Proxy has CORS support
# VITE_LLM_DIRECT=true
# VITE_LLM_PROXY_URL=https://llm-proxy.us01.treasuredata.com
